{
  "spectrum": {
    "total_points": 4096,
    "sw_ppm_range": [1.0e-5, 1.6e-5],
    "field_t": 14.1,
    "gamma_h": 42577413.637,
    "echo_times": [0.0]
  },

  "peaks": {
    "n_peaks": 150,
    "max_couplings": 6,

    "frequency": {
      "condensed_fraction": 0.5,
      "condensed_center_range": [-0.7, 0.7],
      "condensed_spread_range": [0.01, 0.05],
      "non_condensed_std_fraction": 0.25,
      "squash": "tanh"
    },

    "r2": {
      "use_constant_prob": 0.5,
      "constant_value": { "dist": "uniform", "min": 1.0, "max": 6.0 },

      "uniform_fraction": 0.05,
      "uniform": { "dist": "uniform", "min": 0.5, "max": 20.0 },
      "gamma": { "dist": "gamma", "concentration": 10.0, "rate": 10.0 }
    },

    "r2_inhom": {
      "scalar": { "dist": "uniform", "min": 0.1, "max": 3.0 }
    },

    "couplings": {
      "n_couplings": { "dist": "randint", "min": 0, "max_inclusive": 6 },
      "j_hz": { "dist": "uniform", "min": 0.0, "max": 10.0 }
    },

    "amplitude": {
      "raw": { "dist": "uniform", "min": 10.0, "max": 100.0 },
      "nspin": { "dist": "randint", "min": 1, "max_inclusive": 150 },
      "nf_fraction": { "dist": "uniform", "min": -0.5, "max": 1.5 },
      "zero_out_fraction": { "dist": "uniform", "min": 0.0, "max": 0.5 }
    },

    "phase": {
      "phase0_deg_std": 2.5,
      "phase1_deg_std": 2.5
    },

    "hf": {
      "freq_shift_hz": { "dist": "normal", "mean": 0.0, "std": 5.0 }
    }
  },

  "vibration": {
    "vib_max": 80,
    "vib_freq_max": 150.0,
    "vibration_scaling": { "dist": "uniform", "min": 0.001, "max": 0.07 },
    "vib_freq_number": { "dist": "randint", "min": 1, "max_inclusive": 80 },
    "vib_amp": { "dist": "uniform", "min": -100.0, "max": 100.0 },
    "vib_r2": { "dist": "uniform", "min": 0.0, "max": 100.0 }
  },

  "acquisition": {
    "active_points": {
      "enabled": true,
      "min": 2048,
      "max": 4096
    },

    "window": {
      "enabled": true,
      "type": "cos2"
    },

    "noise": {
      "std": { "dist": "uniform", "min": 0.01, "max": 3.0 },
      "shared_hf_nf": true
    },

    "water": {
      "enabled_prob": 0.5,
      "frequency_hz": { "dist": "uniform", "min": -5.0, "max": 5.0 },
      "r2": { "dist": "uniform", "min": 0.5, "max": 20.0 },
      "intensity_factor": { "dist": "uniform", "min": 1.0, "max": 6000.0 },
      "nf_scale": { "dist": "uniform", "min": 0.5, "max": 1.0 },
      "apply_to_hf": true,
      "apply_to_nf": true
    },

    "baseline": {
      "k": {
        "mixture": {
          "p": 0.9,
          "a": { "dist": "normal", "mean": 0.0, "std": 0.05 },
          "b": { "dist": "uniform", "min": -1.0, "max": 1.0 }
        }
      }
    }
  }
}

  